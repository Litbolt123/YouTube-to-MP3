{
  "manifest_version": 3,
  "name": "YouTube Downloader Bridge",
  "version": "1.4.5",
  "description": "Send YouTube videos to the YouTube Downloader desktop app (audio and video).",
  "permissions": ["storage", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://music.youtube.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "action": {
    "default_title": "YouTube Downloader",
    "default_popup": "options.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://music.youtube.com/*"
      ],
      "js": ["api.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}
