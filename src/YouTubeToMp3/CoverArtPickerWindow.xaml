<Window x:Class="YouTubeToMp3.CoverArtPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose cover art"
        Height="560" Width="520"
        MinWidth="460" MinHeight="480"
        Background="{DynamicResource DashBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Cover art" Style="{DynamicResource DashSectionTitle}" Margin="0,0,0,6"/>
            <TextBlock Style="{DynamicResource DashHintText}" TextWrapping="Wrap"
                       Text="Pick one image for this download (including a whole playlist). Useful when some tracks have the wrong YouTube thumbnail — grab a good cover from another video or a local file and reuse it."/>
        </StackPanel>

        <Border Grid.Row="1" Style="{DynamicResource DashCardBorder}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Background="{DynamicResource DashMetricBgBrush}" CornerRadius="6" Padding="8">
                    <Grid>
                        <TextBlock x:Name="PreviewPlaceholder" Text="No custom cover selected"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{DynamicResource DashHintText}"/>
                        <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed"/>
                    </Grid>
                </Border>
                <TextBlock x:Name="StatusText" Grid.Row="1" Style="{DynamicResource DashBodyText}"
                           Margin="0,10,0,0" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{DynamicResource DashCardBorder}" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <Button Content="Browse image file…" Padding="12,8" Margin="0,0,0,10"
                        Style="{DynamicResource DashPrimaryButton}" Click="Browse_OnClick"
                        HorizontalAlignment="Left"/>
                <TextBlock Text="Or fetch a YouTube video’s thumbnail" Style="{DynamicResource DashHintText}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UrlBox" Height="30" Style="{DynamicResource DashTextBox}"
                             VerticalContentAlignment="Center" Padding="8,0"
                             ToolTip="Paste a video URL — thumbnail is fetched automatically for the cover below"
                             TextChanged="UrlBox_OnTextChanged"/>
                    <Button x:Name="FetchFromUrlButton" Grid.Column="1" Content="Fetch" Margin="8,0,0,0" Padding="12,6"
                            Style="{DynamicResource DashToolbarButton}" Click="FetchFromUrl_OnClick"/>
                </Grid>
                <Button Content="Use each video’s default thumbnail" Padding="12,6"
                        Style="{DynamicResource DashToolbarButton}" Click="UseDefault_OnClick"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Padding="14,8" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" IsCancel="True" Click="Cancel_OnClick"/>
            <Button Content="Use this cover for all tracks" Padding="14,8"
                    Style="{DynamicResource DashPrimaryButton}" IsDefault="True" Click="UseForDownload_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
