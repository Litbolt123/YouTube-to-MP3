<Window x:Class="YouTubeToMp3.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Download History"
        Height="560" Width="820"
        MinWidth="700" MinHeight="400"
        Background="{DynamicResource DashBgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Download History" Style="{DynamicResource DashSectionTitle}"/>
            <TextBlock Text="Past downloads grouped by date. Albums and playlists appear as one row; singles show per track."
                       Style="{DynamicResource DashHintText}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{DynamicResource DashCardBorder}" Padding="0">
            <ListView x:Name="HistoryList" BorderThickness="0" Background="Transparent">
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,14,10,4">
                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource DashTextPrimaryBrush}">
                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                        <Run Text="{Binding ItemCount, StringFormat=' ({0})'}"
                                             Foreground="{DynamicResource DashTextMutedBrush}"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <StackPanel>
                                                <ContentPresenter/>
                                                <ItemsPresenter/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Time" Width="90" DisplayMemberBinding="{Binding TimeDisplay}"/>
                        <GridViewColumn Header="Title" Width="240" DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Header="Kind" Width="160" DisplayMemberBinding="{Binding TypeDisplay}"/>
                        <GridViewColumn Header="Saved to" Width="280" DisplayMemberBinding="{Binding OutputPath}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Open file" Padding="12,6" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" Click="OpenFile_OnClick"/>
            <Button x:Name="ImportToMusicHubButton" Content="Import to Music Hub" Padding="12,6" Margin="0,0,8,0"
                    Style="{DynamicResource DashPrimaryButton}" Click="ImportToMusicHub_OnClick" Visibility="Collapsed"/>
            <Button Content="Open folder" Padding="12,6" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" Click="OpenFolder_OnClick"/>
            <Button Content="Re-download" Padding="12,6" Margin="0,0,8,0"
                    Style="{DynamicResource DashPrimaryButton}" Click="Redownload_OnClick"/>
            <Button Content="Close" Padding="12,6"
                    Style="{DynamicResource DashToolbarButton}" IsCancel="True" Click="Close_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
