<Window x:Class="YouTubeToMp3.PlaylistReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Review album tracks"
        Height="640" Width="900"
        MinWidth="720" MinHeight="520"
        Background="{DynamicResource DashBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="CollectionTitleText" Style="{DynamicResource DashSectionTitle}" Margin="0,0,0,6"/>
            <TextBlock Style="{DynamicResource DashHintText}" TextWrapping="Wrap"
                       Text="Album artist and album name apply to the whole release. Per-track Artist is the song credit (can include featured artists). Edit any field, uncheck rows to skip."/>
        </StackPanel>

        <Border Grid.Row="1" Style="{DynamicResource DashCardBorder}" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Album artist" VerticalAlignment="Center" Style="{DynamicResource DashSettingLabel}" Margin="0,0,8,0"/>
                <TextBox x:Name="AlbumArtistBox" Grid.Column="1" Height="30" Style="{DynamicResource DashTextBox}" VerticalContentAlignment="Center" Padding="8,0"/>
                <TextBlock Grid.Column="2" Text="Album" VerticalAlignment="Center" Style="{DynamicResource DashSettingLabel}" Margin="12,0,8,0"/>
                <TextBox x:Name="AlbumNameBox" Grid.Column="3" Height="30" Style="{DynamicResource DashTextBox}" VerticalContentAlignment="Center" Padding="8,0"/>
                <Button Grid.Column="4" Content="Apply to all" Margin="12,0,0,0" Padding="12,6"
                        Style="{DynamicResource DashToolbarButton}" Click="ApplyToAll_OnClick"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{DynamicResource DashCardBorder}" Padding="8">
            <DataGrid x:Name="TracksGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      CellEditEnding="TracksGrid_OnCellEditEnding">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Include" Binding="{Binding Include, UpdateSourceTrigger=PropertyChanged}" Width="64"/>
                    <DataGridTextColumn Header="#" Binding="{Binding Index, Mode=OneWay}" Width="40" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Title" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    <DataGridTextColumn Header="Artist" Binding="{Binding Artist, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                    <DataGridTextColumn Header="Album" Binding="{Binding Album, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                    <DataGridTextColumn Header="Filename" Binding="{Binding FileName, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock x:Name="StatusText" Grid.Row="3" Style="{DynamicResource DashHintText}" Margin="0,10,0,0" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Re-detect" Padding="14,8" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" Click="Redetect_OnClick"/>
            <Button Content="Cancel" Padding="14,8" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" IsCancel="True"/>
            <Button Content="Download album" Padding="16,8"
                    Style="{DynamicResource DashPrimaryButton}" IsDefault="True" Click="Download_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
