<Window x:Class="YouTubeToMp3.QueueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Download Queue"
        Height="680" Width="1000"
        MinWidth="800" MinHeight="520"
        Background="{DynamicResource DashBgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Download Queue" Style="{DynamicResource DashSectionTitle}" Margin="0,0,0,12"/>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <Border Style="{DynamicResource DashCardBorder}" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Status" Style="{DynamicResource DashHintText}"/>
                    <TextBlock x:Name="MetricStatusText" Style="{DynamicResource DashBodyText}" FontWeight="SemiBold"
                               Margin="0,4,0,0" TextWrapping="Wrap" Text="—"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource DashCardBorder}" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Queue ETA" Style="{DynamicResource DashHintText}"/>
                    <TextBlock x:Name="MetricQueueEtaText" Style="{DynamicResource DashBodyText}" FontWeight="SemiBold"
                               Margin="0,4,0,0" Text="—"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource DashCardBorder}" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="File ETA" Style="{DynamicResource DashHintText}"/>
                    <TextBlock x:Name="MetricFileEtaText" Style="{DynamicResource DashBodyText}" FontWeight="SemiBold"
                               Margin="0,4,0,0" Text="—"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource DashCardBorder}" Padding="12">
                <StackPanel>
                    <TextBlock Text="Speed" Style="{DynamicResource DashHintText}"/>
                    <TextBlock x:Name="MetricSpeedText" Style="{DynamicResource DashBodyText}" FontWeight="SemiBold"
                               Margin="0,4,0,0" Text="—"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border x:Name="ActiveCard" Grid.Row="2" Style="{DynamicResource DashCardBorder}" Padding="14" Margin="0,0,0,12" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="96" Height="96" CornerRadius="6" Margin="0,0,14,0"
                        Background="{DynamicResource DashMetricBgBrush}" ClipToBounds="True" VerticalAlignment="Top">
                    <Grid>
                        <TextBlock x:Name="ActiveCoverPlaceholder" Text="Cover"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{DynamicResource DashHintText}" TextAlignment="Center"/>
                        <Image x:Name="ActiveCoverImage" Stretch="Uniform"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1">
                <TextBlock Text="Now downloading" FontSize="11" Foreground="{DynamicResource DashAccentBrush}"/>
                <TextBlock x:Name="ActiveTitleText" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource DashTextPrimaryBrush}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                <ProgressBar x:Name="ActiveProgressBar" Height="10" Minimum="0" Maximum="100" Margin="0,0,0,8"/>
                <TextBlock x:Name="ActiveProgressText" Style="{DynamicResource DashBodyText}" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Type" Style="{DynamicResource DashHintText}"/>
                    <TextBlock x:Name="ActiveKindText" Grid.Row="0" Grid.Column="1" Style="{DynamicResource DashBodyText}" Margin="0,0,12,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Format" Style="{DynamicResource DashHintText}"/>
                    <TextBlock x:Name="ActiveFormatText" Grid.Row="0" Grid.Column="3" Style="{DynamicResource DashBodyText}" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Quality" Style="{DynamicResource DashHintText}"/>
                    <TextBlock x:Name="ActiveQualityText" Grid.Row="1" Grid.Column="1" Style="{DynamicResource DashBodyText}" Margin="0,0,12,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Scope" Style="{DynamicResource DashHintText}"/>
                    <TextBlock x:Name="ActiveScopeText" Grid.Row="1" Grid.Column="3" Style="{DynamicResource DashBodyText}" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Save to" Style="{DynamicResource DashHintText}" VerticalAlignment="Top"/>
                    <TextBlock x:Name="ActiveFolderText" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                               Style="{DynamicResource DashBodyText}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                </Grid>
                <TextBlock Text="URL" Style="{DynamicResource DashHintText}" Margin="0,4,0,2"/>
                <TextBox x:Name="ActiveUrlText" IsReadOnly="True" Style="{DynamicResource DashTextBox}"
                         TextWrapping="Wrap" Background="{DynamicResource DashMetricBgBrush}" Padding="8,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{DynamicResource DashCardBorder}" Padding="0">
            <ListView x:Name="QueueItemsList" BorderThickness="0" Background="Transparent"
                      SelectionChanged="QueueItemsList_OnSelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="#" Width="40" DisplayMemberBinding="{Binding Position}"/>
                        <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding Status}"/>
                        <GridViewColumn Header="Title" Width="220" DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Header="Progress" Width="150" DisplayMemberBinding="{Binding Progress}"/>
                        <GridViewColumn Header="Type" Width="70" DisplayMemberBinding="{Binding Kind}"/>
                        <GridViewColumn Header="Format" Width="80" DisplayMemberBinding="{Binding Format}"/>
                        <GridViewColumn Header="Quality" Width="110" DisplayMemberBinding="{Binding Quality}"/>
                        <GridViewColumn Header="Scope" Width="70" DisplayMemberBinding="{Binding Scope}"/>
                        <GridViewColumn Header="Save to" Width="220" DisplayMemberBinding="{Binding Folder}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="PauseResumeButton" Content="Pause queue" Padding="12,6" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" Click="PauseResume_OnClick"/>
            <Button Content="Open folder" Padding="12,6" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" Click="OpenFolder_OnClick"/>
            <Button Content="Move up" Padding="12,6" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" Click="MoveUp_OnClick"/>
            <Button Content="Move down" Padding="12,6" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" Click="MoveDown_OnClick"/>
            <Button Content="Remove" Padding="12,6" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" Click="Remove_OnClick"/>
            <Button Content="Clear queue" Padding="12,6" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" Click="Clear_OnClick"/>
            <Button x:Name="CancelActiveButton" Content="Cancel download" Padding="12,6" Margin="0,0,8,0"
                    Style="{DynamicResource DashToolbarButton}" Click="CancelActive_OnClick" Visibility="Collapsed"/>
            <Button Content="Close" Padding="12,6" Style="{DynamicResource DashToolbarButton}" IsCancel="True" Click="Close_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
